# ======================================================================
# RTAIP SOCIAL — environment template
# Copy to .env.local for development. NEVER commit a populated .env.
# AI / payment keys live in apps/jobs only (workers). The web app gets
# only what's safe for server-side Next.js routes.
# ======================================================================

# --- Supabase ---------------------------------------------------------
# Public anon key — safe for the browser via NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service-role key — TRIGGER.DEV WORKERS ONLY. Bypasses RLS.
# Never expose with NEXT_PUBLIC_. Never read from any code in apps/web.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Optional: db connection string for migrations / Supabase CLI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- Trigger.dev v3 ---------------------------------------------------
# Server-side only. Used by apps/web to enqueue tasks; used by apps/jobs to run them.
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_REF=proj_...

# --- AI providers (workers only — apps/jobs) --------------------------
ANTHROPIC_API_KEY=sk-ant-...
# KIE.ai aggregator API key. Used for Nano Banana Pro (image) +
# Seedance 2.0 (video). Get from https://kie.ai → Settings → API.
KIE_AI_API_KEY=kie_...
# Higgsfield NOT used in v1 — REST is enterprise-gated. Personal
# Higgsfield MCP is a dev/QA tool only, not a production credential.
# Identity Lock (SOUL) deferred to v1.5 → Replicate Flux LoRA.

# --- Stripe (subscriptions + metered billing) -------------------------
# Use TEST keys for development. NEVER mix test and live.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (Resend) ---------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@your-domain.com

# --- Analytics (PostHog) ----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- App config -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
